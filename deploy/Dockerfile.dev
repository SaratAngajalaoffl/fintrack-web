# Development Next.js (`npm run dev`); compose bind-mounts the app tree over /app/web.
FROM node:22-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app/web

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

EXPOSE 3000

CMD ["sh", "-c", "if [ ! -d node_modules/.bin ]; then npm ci; fi && exec npm run dev -- --hostname 0.0.0.0 --port 3000"]
