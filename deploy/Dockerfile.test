# CI: ESLint → JUnit (`eslint-junit.xml`) + `next build` (docker-compose.test.yml, profile web-tests).
FROM node:22-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app/web

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

ENV API_ORIGIN=http://api:8080
ENV NODE_ENV=test
ENV NEXT_TELEMETRY_DISABLED=1
ENV CI=1

CMD ["sh", "-c", "if [ ! -d node_modules/.bin ]; then npm ci; fi && npm run lint:junit && npm run build"]
