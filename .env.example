# Copy to .env.local or .env in this directory — Next.js loads env files from web/
# Session JWTs are signed only by the Go API. Next validates sessions via GET /api/auth/me
# (middleware + getSession) through same-origin `/api/*` routes.

# Used by Next.js server code when set (e.g. DB access from Route Handlers).
DATABASE_URL=postgresql://fintrack:fintrack@localhost:5432/fintrack

# Browser calls same-origin `/api/*` (see getApiOrigin); Next rewrites those to the Go API.
# Set API_ORIGIN so `next.config` rewrites and middleware/getSession reach the API:
# Local Go (default listen): http://127.0.0.1:8080 — Docker Compose (web → api service): http://api:8000
API_ORIGIN=http://127.0.0.1:8080

# Optional: GitHub link in the header (defaults if unset)
# NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername/fintrack
